# Cloudflare Worker URL (no trailing slash)
# This is the same worker that runs the rickroll counter.
WORKER_URL=https://barrelroll-counter-worker.naimean.workers.dev

# Shared secret — must match the value set on the worker via:
#   wrangler secret put ROUTER_SECRET
ROUTER_SECRET=your-secret-here

# RS200 local network address (default is usually correct)
ROUTER_IP=192.168.1.1

# Router admin credentials (these never leave this machine)
ROUTER_USER=admin
ROUTER_PASS=your-router-password-here

# RS200 API paths — only change these if your firmware uses different endpoints
ROUTER_LOGIN_PATH=/api/auth
ROUTER_REBOOT_PATH=/api/system/reboot
